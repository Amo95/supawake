{
  "name": "supawake",
  "version": "1.0.0",
  "description": "Keep Supabase free-tier databases active by pinging them periodically to prevent auto-pause.",
  "keywords": [
    "supabase",
    "keep-alive",
    "ping",
    "cli",
    "cron",
    "free-tier",
    "auto-pause"
  ],
  "license": "MIT",
  "author": "",
  "main": "dist/index.js",
  "bin": {
    "supawake": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "node-cron": "^3.0.3",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
